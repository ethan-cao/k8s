                </mxCell>
                <mxCell id="254" value="&lt;div style=&quot;font-size: 15px;&quot;&gt;when PVC is submitted to API_Server, it gets created in Pending status&lt;/div&gt;&lt;div style=&quot;font-size: 15px;&quot;&gt;csi-controller pods watch for PVC via API_Server, and finds the newly created PVC&lt;/div&gt;&lt;div style=&quot;font-size: 15px;&quot;&gt;csi-controller checks the PVC&#39;s provisioner&lt;/div&gt;&lt;div style=&quot;font-size: 15px;&quot;&gt;if csi-controller understands the provisioner&lt;/div&gt;&lt;div style=&quot;font-size: 15px;&quot;&gt;csi-controller calls the right party to create the volume&lt;/div&gt;&lt;div style=&quot;font-size: 15px;&quot;&gt;&amp;nbsp; &amp;nbsp;e.g. the ebs-csi-controller calls AWS to create EBS volume&lt;/div&gt;&lt;div style=&quot;font-size: 15px;&quot;&gt;PV controller binds the PV to PVC, set status in both to Bound&lt;/div&gt;&lt;div style=&quot;font-size: 15px;&quot;&gt;&lt;b style=&quot;border-color: var(--border-color);&quot;&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 15px;&quot;&gt;&lt;b style=&quot;border-color: var(--border-color);&quot;&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 15px;&quot;&gt;&lt;b style=&quot;border-color: var(--border-color);&quot;&gt;csi-node pod:&amp;nbsp;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 15px;&quot;&gt;&lt;ul&gt;&lt;li&gt;It runs as daemonSet in all worker nodes&lt;/li&gt;&lt;li&gt;It mounts/un-mounts/format volume&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 15px;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 15px;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 15px;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 15px;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 15px;&quot;&gt;&lt;div&gt;&lt;b style=&quot;border-color: var(--border-color);&quot;&gt;csi-controller pod:&amp;nbsp;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;It runs as Deployment in a few nodes&lt;/li&gt;&lt;li&gt;it does the actual work to manage disk ()&amp;nbsp;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
